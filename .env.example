POSTGRES_USER=hatch
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hatch

ALLOWED_ORIGIN=http://localhost:5173

GITHUB_WEBHOOK_SECRET=generate_a_long_random_string_here
GITHUB_APP_ENABLED=true
GITHUB_APP_ID=

# Comma-separated GitHub owners (user/org) allowed to trigger builds.
# The hatchpr GitHub App is public: without this allowlist any stranger
# could install it on their repo and run arbitrary Dockerfiles on this host.
# Empty value = every webhook is denied (fail-closed).
HATCH_ALLOWED_OWNERS=itsaam

HATCH_DOMAIN=localhost

# Preview lifecycle
PREVIEW_TTL_HOURS=168
PREVIEW_REAPER_INTERVAL_MINUTES=60
